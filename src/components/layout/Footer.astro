---
import { copy } from '@/data/copy'

const { footer, nav, finalCta } = copy

const WA_HREF = `https://wa.me/573001234567?text=${encodeURIComponent('Hola IndexArts, quiero el diagnóstico gratuito.')}`
---

<style>
  @keyframes ia-marquee {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  .ia-marquee-track {
    animation: ia-marquee 36s linear infinite;
  }
  .ia-marquee-track:hover {
    animation-play-state: paused;
  }

  .ia-back-top svg {
    transition: transform 250ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ia-back-top:hover svg {
    transform: translateY(-4px);
  }

  .ia-footer-link {
    position: relative;
  }
  .ia-footer-link::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    width: 0;
    height: 1px;
    background: #c0392b;
    transition: width 300ms cubic-bezier(0.16, 1, 0.3, 1);
  }
  .ia-footer-link:hover::after {
    width: 100%;
  }

  .ia-bg-text {
    font-size: clamp(56px, 14vw, 200px);
    line-height: 0.85;
    font-weight: 900;
    letter-spacing: -0.04em;
    color: transparent;
    -webkit-text-stroke: 1px rgba(242, 237, 230, 0.04);
    user-select: none;
    pointer-events: none;
    white-space: nowrap;
    overflow: hidden;
    max-width: 100%;
  }

  /* ── Footer contenedor ── */
  .ia-footer {
    background-color: #0c0c0c;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  /* ── Marquee ── */
  .ia-marquee-wrap {
    width: 100%;
    overflow: hidden;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding-block: 13px;
    flex-shrink: 0;
  }

  /* ── Centro CTA ── */
  .ia-footer-center {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: clamp(48px, 9vw, 96px) clamp(16px, 6vw, 48px);
    flex: 1;
    overflow: hidden;
    gap: clamp(24px, 4vw, 40px);
  }

  /* Texto INDEXARTS de fondo — absoluto, no corta el layout */
  .ia-footer-bg-wrap {
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%) translateY(18%);
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .ia-footer-center > * {
    position: relative;
    z-index: 1;
  }

  /* ── Heading ── */
  .ia-footer-eyebrow {
    font-family: var(--font-mono);
    font-size: clamp(8px, 1.1vw, 11px);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.4);
    margin-bottom: clamp(12px, 2vw, 20px);
  }

  .ia-footer-h2 {
    font-family: var(--font-head);
    font-size: clamp(2rem, 7vw, 5.5rem);
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--color-cream-100, #f2ede6);
    margin: 0;
  }

  .ia-footer-h2 em {
    color: var(--color-brand-red, #c0392b);
    font-style: normal;
  }

  /* ── CTA button ── */
  .ia-footer-cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-body);
    font-size: clamp(12px, 1.3vw, 14px);
    font-weight: 600;
    color: var(--color-cream-100, #f2ede6);
    border: 1px solid rgba(255, 255, 255, 0.12);
    padding: clamp(12px, 1.8vw, 14px) clamp(20px, 3vw, 28px);
    text-decoration: none;
    transition:
      border-color 0.3s ease,
      background 0.3s ease;
    min-height: 48px;
  }

  .ia-footer-cta:hover {
    border-color: rgba(192, 57, 43, 0.5);
    background: rgba(192, 57, 43, 0.06);
  }

  .ia-footer-cta svg {
    color: var(--color-brand-red, #c0392b);
    flex-shrink: 0;
  }

  .ia-footer-cta-arrow {
    color: rgba(242, 237, 230, 0.3);
    transition:
      color 0.3s ease,
      transform 0.3s ease;
  }

  .ia-footer-cta:hover .ia-footer-cta-arrow {
    color: var(--color-brand-red, #c0392b);
    transform: translateX(3px);
  }

  /* ── Trust signals ── */
  .ia-trust-list {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 24px;
  }

  .ia-trust-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: clamp(9px, 1vw, 11px);
    color: rgba(242, 237, 230, 0.35);
    line-height: 1.4;
  }

  .ia-trust-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Bottom bar ── */
  .ia-footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding: clamp(16px, 2.5vw, 20px) clamp(16px, 5vw, 32px);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  @media (min-width: 640px) {
    .ia-footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }

  .ia-footer-logo {
    font-family: var(--font-body);
    font-weight: 700;
    font-size: clamp(14px, 1.6vw, 18px);
    color: rgba(242, 237, 230, 0.6);
    text-decoration: none;
    transition: color 0.2s ease;
    letter-spacing: -0.01em;
  }
  .ia-footer-logo:hover {
    color: var(--color-cream-100, #f2ede6);
  }
  .ia-footer-logo span {
    color: var(--color-brand-red, #c0392b);
  }

  .ia-footer-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px 20px;
  }

  .ia-footer-right {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .ia-copyright {
    font-family: var(--font-mono);
    font-size: clamp(8px, 0.9vw, 10px);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.25);
    white-space: nowrap;
  }

  .ia-back-top {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: transparent;
    color: rgba(242, 237, 230, 0.4);
    cursor: pointer;
    transition:
      border-color 0.3s ease,
      color 0.3s ease;
    flex-shrink: 0;
  }

  .ia-back-top:hover {
    border-color: rgba(192, 57, 43, 0.4);
    color: var(--color-cream-100, #f2ede6);
  }

  /* Mobile: ocultar links del footer en pantallas muy pequeñas, dejar solo email */
  @media (max-width: 480px) {
    .ia-footer-nav-link-secondary {
      display: none;
    }
  }
</style>

<footer class="ia-footer" aria-label="Pie de página">
  <!-- ── Marquee ── -->
  <div class="ia-marquee-wrap" aria-hidden="true">
    <div
      class="ia-marquee-track"
      style="display:flex; width:max-content; align-items:center; gap:0;"
    >
      <div
        style="display:flex; align-items:center; gap:40px; padding:0 32px; font-family:var(--font-mono); font-size:11px; letter-spacing:0.25em; text-transform:uppercase; color:rgba(242,237,230,0.28);"
      >
        <span>Webs que venden</span>
        <span style="color:#C0392B;">✦</span>
        <span>Automatizaciones 24/7</span>
        <span style="color:rgba(192,57,43,0.4);">✦</span>
        <span>Garantía 60 días</span>
        <span style="color:#C0392B;">✦</span>
        <span>Barranquilla · Colombia</span>
        <span style="color:rgba(192,57,43,0.4);">✦</span>
        <span>Sistemas que escalan</span>
        <span style="color:#C0392B;">✦</span>
        <span>Resultados en COP real</span>
        <span style="color:rgba(192,57,43,0.4);">✦</span>
      </div>
      <!-- Bloque espejo para loop infinito -->
      <div
        aria-hidden="true"
        style="display:flex; align-items:center; gap:40px; padding:0 32px; font-family:var(--font-mono); font-size:11px; letter-spacing:0.25em; text-transform:uppercase; color:rgba(242,237,230,0.28);"
      >
        <span>Webs que venden</span>
        <span style="color:#C0392B;">✦</span>
        <span>Automatizaciones 24/7</span>
        <span style="color:rgba(192,57,43,0.4);">✦</span>
        <span>Garantía 60 días</span>
        <span style="color:#C0392B;">✦</span>
        <span>Barranquilla · Colombia</span>
        <span style="color:rgba(192,57,43,0.4);">✦</span>
        <span>Sistemas que escalan</span>
        <span style="color:#C0392B;">✦</span>
        <span>Resultados en COP real</span>
        <span style="color:rgba(192,57,43,0.4);">✦</span>
      </div>
    </div>
  </div>

  <!-- ── Centro — CTA principal ── -->
  <div class="ia-footer-center">
    <!-- INDEXARTS de fondo -->
    <div class="ia-footer-bg-wrap" aria-hidden="true">
      <div class="ia-bg-text">INDEXARTS</div>
    </div>

    <!-- Heading -->
    <div>
      <p class="ia-footer-eyebrow">{finalCta.eyebrow}</p>
      <h2 class="ia-footer-h2">
        {finalCta.h2.line1}<br />
        <em>{finalCta.h2.emphasis}</em>
        {
          finalCta.h2.line3 && (
            <>
              <br />
              {finalCta.h2.line3}
            </>
          )
        }
      </h2>
    </div>

    <!-- CTA WhatsApp -->

  <a  href={WA_HREF}
    target="_blank" rel="noopener noreferrer" class="ia-footer-cta" aria-label="Abrir WhatsApp con IndexArts"
    >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path
        d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.841.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
      ></path>
    </svg>
    {finalCta.cta}
    <span class="ia-footer-cta-arrow">→</span>
  </div>

  <!-- Trust signals -->
  <div class="ia-trust-list" role="list">
    {
      finalCta.trust.map((item) => (
        <span class="ia-trust-item" role="listitem">
          <span
            class="ia-trust-dot"
            aria-hidden="true"
            style={`background: ${item.dot === 'green' ? 'var(--color-brand-green, #0B7A45)' : 'rgba(242,237,230,0.20)'};`}
          />
          {item.text}
        </span>
      ))
    }
  </div>
</footer>

<!-- ── Bottom bar ── -->
<div class="ia-footer-bottom">
  <!-- Logo -->
  <a href="/" class="ia-footer-logo">
    Index<span>{footer.logoAccent}</span>
  </a>

  <!-- Links -->
  <nav class="ia-footer-nav" aria-label="Links del footer">
    {
      nav.links.map((link) => (
        <a
          href={link.href}
          class="ia-footer-link ia-footer-nav-link-secondary font-body text-cream-100/40 hover:text-cream-100 transition-colors duration-200"
          style="font-size: clamp(10px, 1.1vw, 12px);"
        >
          {link.label}
        </a>
      ))
    }

   <a href="mailto:hola@indexarts.co" class="ia-footer-link font-mono text-cream-100/30
    hover:text-cream-100/70 transition-colors duration-200" style="font-size: clamp(9px, 1vw,
    11px);" > hola@indexarts.co
  </nav>
</div>

<!-- Copyright + back to top -->
<div class="ia-footer-right">
  <p class="ia-copyright">{footer.copyright}</p>
  <button id="ia-back-top" class="ia-back-top" aria-label="Volver al inicio">
    <svg
      width="14"
      height="14"
      viewBox="0 0 14 14"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
    >
      <path d="M7 11V3M3 6l4-4 4 4" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
  </button>
</div>

<script>
  document.getElementById('ia-back-top')?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' })
  })
</script>
