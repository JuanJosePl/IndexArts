---
/**
 * src/components/sections/Pain.astro
 *
 * Sección "El costo real de no tener el sistema".
 * Datos desde copy (strings) — sin props adicionales.
 * Animaciones con IntersectionObserver via clases .reveal-left / .is-visible
 */
import { copy } from '@/data/copy'

const { pain } = copy
---

<section
  id="dolor"
  style="padding: var(--section-py) var(--section-px); background-color: var(--color-ink-950);"
>
  <div style="max-width: 700px;">

    <!-- Eyebrow -->
    <span
      class="font-mono text-cream-100/30 uppercase tracking-[0.18em] text-[9px]
             inline-block mb-11 pb-1.5"
      style="border-bottom: 1px solid var(--color-border-2);"
    >
      {pain.eyebrow}
    </span>

    <!-- Preguntas -->
    <div class="flex flex-col">
      {pain.questions.map((q, i) => (
        <div
          class="pain-question reveal-left"
          style={`padding: 0 0 40px 22px; border-left: 1px solid var(--color-border); transition-delay: ${i * 140}ms;`}
          data-index={i}
        >
          <p
            class="font-head text-cream-200/85 leading-snug mb-2"
            style="font-size: clamp(17px, 2.6vw, 26px); font-weight: 400;"
          >
            {/* Separar el texto en dos partes para resaltar el énfasis */}
            {q.h.replace(q.hEmphasis, '').trim()}
            {' '}
            <em class="text-cream-100 italic font-bold">{q.hEmphasis}</em>
          </p>
          <p class="text-[12px] text-cream-100/30 leading-relaxed max-w-[440px]">
            {q.note}
          </p>
        </div>
      ))}
    </div>

    <!-- Punch line -->
    <div
      class="pain-punch reveal"
      style="border-top: 1px solid var(--color-border); padding-top: 36px; transition-delay: 480ms;"
    >
      <p
        class="font-head italic text-cream-100 mb-5"
        style="font-size: clamp(17px, 2.4vw, 24px);"
      >
        {pain.punch}
        {' '}
        <em class="text-brand-red not-italic font-bold">{pain.punchEmphasis}</em>
      </p>
      
       <a href={pain.punchCtaHref}
        class="group inline-flex items-center gap-2 text-[13px] text-cream-100/65
               transition-colors duration-200 hover:text-cream-100"
      >
        {pain.punchCta}
        <span class="inline-block transition-transform duration-200 group-hover:translate-x-1">→</span>
      </a>
    </div>

  </div>
</section>

<script>
  // IntersectionObserver local — sin dependencia de utils
  // Activa .is-visible en .reveal-left y .reveal al entrar en viewport
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible')
          // Bordes rojos en las preguntas al activarse
          const el = entry.target as HTMLElement
          if (el.classList.contains('pain-question')) {
            el.style.borderLeftColor = 'var(--color-brand-red)'
          }
          io.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.15 }
  )

  document
    .querySelectorAll('#dolor .reveal-left, #dolor .reveal')
    .forEach((el) => io.observe(el))
</script>