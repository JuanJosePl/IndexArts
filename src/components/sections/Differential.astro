---
/**
 * src/components/sections/Differential.astro
 *
 * Sección "Por qué no somos otra agencia".
 * Fondo: cream (#E8E2D9) — inverso al mundo oscuro.
 * Tabla comparativa con reveal staggered por fila.
 * Promesa de garantía como cierre editorial.
 *
 * Datos: solo copy — sin props, sin dataStore.
 */
import { copy } from '@/data/copy'

const { differential: d } = copy
---

<section
  id="diferencial"
  aria-label="Por qué IndexArts"
  class="diff-section"
>

  {/* ── Ruido de fondo — solo CSS ── */}
  <div class="diff-noise" aria-hidden="true"></div>

  <div class="diff-inner">

    {/* ── Eyebrow ── */}
    <div class="diff-eyebrow-row reveal">
      <span class="diff-eyebrow font-mono">{d.eyebrow}</span>
      <div class="diff-eyebrow-line" aria-hidden="true"></div>
    </div>

    {/* ── Tabla ── */}
    <div class="diff-table-wrap" role="table" aria-label="Comparativa IndexArts vs agencias típicas">

      {/* Cabecera */}
      <div class="diff-thead" role="row">
        <div class="diff-th diff-th--aspect font-mono" role="columnheader">{d.tableHeaders.aspect}</div>
        <div class="diff-th diff-th--others font-mono" role="columnheader">{d.tableHeaders.others}</div>
        <div class="diff-th diff-th--ours font-mono" role="columnheader">{d.tableHeaders.ours}</div>
      </div>

      {/* Filas */}
      {d.rows.map((row, i) => (
        <div
          class="diff-row reveal"
          role="row"
          style={`transition-delay: ${i * 80}ms`}
          data-index={i}
        >
          {/* Aspecto */}
          <div class="diff-cell diff-cell--aspect" role="cell">
            <span class="diff-aspect-num font-mono">{String(i + 1).padStart(2, '0')}</span>
            <span class="diff-aspect-label font-body">{row.aspect}</span>
          </div>

          {/* Agencias típicas */}
          <div
            class={`diff-cell diff-cell--others ${row.othersNegative ? 'is-negative' : ''}`}
            role="cell"
          >
            {row.othersNegative && (
              <span class="diff-mark diff-mark--neg" aria-hidden="true">✕</span>
            )}
            <span class="diff-cell-text font-body">{row.others}</span>
          </div>

          {/* IndexArts */}
          <div
            class={`diff-cell diff-cell--ours ${row.oursPositive ? 'is-positive' : ''}`}
            role="cell"
          >
            {row.oursPositive && (
              <span class="diff-mark diff-mark--pos" aria-hidden="true">✓</span>
            )}
            <span class="diff-cell-text font-body">{row.ours}</span>
          </div>
        </div>
      ))}
    </div>

    {/* ── Promesa de garantía ── */}
    <blockquote class="diff-promise reveal" style="transition-delay: 480ms;">
      <div class="diff-promise-bar" aria-hidden="true"></div>
      <div class="diff-promise-inner">
        <p class="diff-promise-text font-head">
          {d.promise}
          {' '}
          <em class="diff-promise-em">{d.promiseEmphasis}</em>
          {' '}
          <span class="diff-promise-suffix">{d.promiseSuffix}</span>
        </p>
        <cite class="diff-promise-cite font-mono">— IndexArts · Barranquilla, Colombia</cite>
      </div>
    </blockquote>

  </div>
</section>

<style>
  /* ── Sección ──────────────────────────────────────────────────────────────── */
  .diff-section {
    position: relative;
    background-color: var(--color-cream-200, #E8E2D9);
    padding: var(--section-py) var(--section-px);
    color: #1A1A1A;
    overflow: hidden;
    isolation: isolate;
  }

  /* ── Noise overlay — SVG inline codificado ── */
  .diff-noise {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.028;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
  }

  /* ── Contenedor interior ── */
  .diff-inner {
    position: relative;
    z-index: 1;
    max-width: var(--width-content, 1080px);
    margin: 0 auto;
  }

  /* ── Eyebrow row ── */
  .diff-eyebrow-row {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: clamp(44px, 7vw, 72px);
  }

  .diff-eyebrow {
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.35);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .diff-eyebrow-line {
    height: 1px;
    flex: 1;
    background: rgba(26, 26, 26, 0.12);
    transform-origin: left;
    animation: line-grow-dark 1.2s 0.3s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  @keyframes line-grow-dark {
    from { transform: scaleX(0); opacity: 0; }
    to   { transform: scaleX(1); opacity: 1; }
  }

  /* ── Tabla ── */
  .diff-table-wrap {
    display: flex;
    flex-direction: column;
    border: 1px solid rgba(26, 26, 26, 0.10);
  }

  /* Cabecera */
  .diff-thead {
    display: grid;
    grid-template-columns: 1fr 1.4fr 1.4fr;
    background-color: rgba(26, 26, 26, 0.04);
    border-bottom: 1px solid rgba(26, 26, 26, 0.10);
  }

  .diff-th {
    padding: 11px 18px;
    font-size: 8px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.35);
  }

  .diff-th--others {
    border-left: 1px solid rgba(26, 26, 26, 0.10);
  }

  .diff-th--ours {
    border-left: 1px solid rgba(26, 26, 26, 0.10);
    color: var(--color-brand-red, #C0392B);
    opacity: 0.75;
  }

  /* Filas */
  .diff-row {
    display: grid;
    grid-template-columns: 1fr 1.4fr 1.4fr;
    border-bottom: 1px solid rgba(26, 26, 26, 0.08);
    transition:
      background-color 0.25s ease,
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .diff-row:last-child { border-bottom: none; }

  .diff-row:hover {
    background-color: rgba(26, 26, 26, 0.025);
  }

  /* Celdas */
  .diff-cell {
    padding: clamp(14px, 2.5vw, 22px) 18px;
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-size: clamp(12px, 1.3vw, 14px);
    line-height: 1.55;
    color: rgba(26, 26, 26, 0.7);
  }

  .diff-cell--aspect {
    flex-direction: row;
    align-items: center;
    gap: 12px;
  }

  .diff-cell--others {
    border-left: 1px solid rgba(26, 26, 26, 0.08);
  }

  .diff-cell--ours {
    border-left: 1px solid rgba(26, 26, 26, 0.08);
  }

  .diff-cell--others.is-negative .diff-cell-text {
    color: rgba(26, 26, 26, 0.42);
  }

  .diff-cell--ours.is-positive .diff-cell-text {
    color: rgba(26, 26, 26, 0.85);
    font-weight: 500;
  }

  /* Aspecto */
  .diff-aspect-num {
    font-size: 9px;
    color: rgba(26, 26, 26, 0.22);
    letter-spacing: 0.08em;
    flex-shrink: 0;
    width: 20px;
    line-height: 1;
  }

  .diff-aspect-label {
    font-size: clamp(12px, 1.3vw, 13px);
    font-weight: 600;
    color: rgba(26, 26, 26, 0.78);
    line-height: 1.35;
  }

  /* Marcas ✕ ✓ */
  .diff-mark {
    font-size: 10px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .diff-mark--neg {
    color: rgba(180, 60, 40, 0.38);
    font-family: var(--font-mono);
  }

  .diff-mark--pos {
    color: var(--color-brand-green, #0B7A45);
    font-family: var(--font-mono);
  }

  /* Highlight en la columna IndexArts */
  .diff-cell--ours {
    background-color: rgba(192, 57, 43, 0.018);
    position: relative;
  }

  /* Línea izquierda roja en columna propia */
  .diff-cell--ours::before {
    content: '';
    position: absolute;
    left: 0;
    top: 12px;
    bottom: 12px;
    width: 2px;
    background: var(--color-brand-red, #C0392B);
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .diff-row:hover .diff-cell--ours::before {
    opacity: 0.6;
  }

  /* ── Promesa ── */
  .diff-promise {
    margin: clamp(44px, 7vw, 72px) 0 0;
    padding: 0;
    display: flex;
    align-items: flex-start;
    gap: 28px;
    max-width: 720px;
  }

  .diff-promise-bar {
    flex-shrink: 0;
    width: 3px;
    background: var(--color-brand-red, #C0392B);
    align-self: stretch;
    min-height: 80px;
    border-radius: 0;
  }

  .diff-promise-inner {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .diff-promise-text {
    font-size: clamp(18px, 2.8vw, 28px);
    font-weight: 400;
    line-height: 1.4;
    color: rgba(26, 26, 26, 0.82);
    font-style: italic;
    margin: 0;
  }

  .diff-promise-em {
    color: #1A1A1A;
    font-weight: 700;
    font-style: italic;
  }

  .diff-promise-suffix {
    color: rgba(26, 26, 26, 0.55);
    font-style: normal;
    font-size: 0.88em;
  }

  .diff-promise-cite {
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(26, 26, 26, 0.28);
    font-style: normal;
  }

  /* ── Reveal (heredado del global.css para fondo claro) ── */
  /* Las clases .reveal / .is-visible vienen del global.css
     pero aquí sobreescribimos el color de inicio para fondo claro */
  .diff-section .reveal {
    opacity: 0;
    transform: translateY(18px);
    transition:
      opacity  0.72s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.72s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .diff-section .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media (max-width: 720px) {
    .diff-thead {
      display: none;  /* columnas colapsan — se muestran como cards */
    }

    .diff-row {
      grid-template-columns: 1fr;
      gap: 0;
      padding-bottom: 0;
    }

    .diff-cell {
      border-left: none !important;
    }

    .diff-cell--aspect {
      background-color: rgba(26, 26, 26, 0.04);
      padding: 14px 18px 10px;
    }

    .diff-cell--others::before {
      content: 'Agencias típicas';
      display: block;
      font-family: var(--font-mono);
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(26, 26, 26, 0.28);
      margin-bottom: 4px;
    }

    .diff-cell--ours::before {
      position: static !important;
      width: auto !important;
      height: auto !important;
      background: none !important;
      opacity: 1 !important;
      content: 'IndexArts';
      display: block;
      font-family: var(--font-mono);
      font-size: 8px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(192, 57, 43, 0.7);
      margin-bottom: 4px;
    }

    /* Reaplicar borde izquierdo rojo en mobile solo como borde-section */
    .diff-cell--ours {
      border-left: 2px solid rgba(192, 57, 43, 0.25) !important;
    }
  }
</style>

<script>
  // IntersectionObserver — activa .is-visible en los .reveal del diferencial
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible')
          io.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.12 }
  )

  document
    .querySelectorAll('#diferencial .reveal')
    .forEach((el) => io.observe(el))
</script>