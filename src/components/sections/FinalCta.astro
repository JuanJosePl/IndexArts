---
/**
 * src/components/sections/FinalCta.astro
 */
import { copy } from '@/data/copy'

const { finalCta: f, footer } = copy

const WA_PHONE = import.meta.env.PUBLIC_WA_PHONE ?? '573001234567'
const WA_MSG = encodeURIComponent('Hola, quiero mi diagnóstico gratuito ahora.')
const WA_HREF = `https://wa.me/${WA_PHONE}?text=${WA_MSG}`

const DOT_COLORS: Record<string, string> = {
  green: 'var(--color-brand-green, #0B7A45)',
  neutral: 'rgba(242,237,230,0.28)',
  red: 'var(--color-brand-red, #C0392B)',
}
---

<section id="final" aria-label="Contactar a IndexArts" class="final-section">
  <div class="final-noise" aria-hidden="true"></div>
  <div class="final-glow" aria-hidden="true"></div>

  <div class="final-inner">
    <div class="final-content">
      <span class="final-eyebrow reveal font-mono">{f.eyebrow}</span>

      <h2 class="final-h2 font-head" aria-label={`${f.h2.line1} ${f.h2.emphasis} ${f.h2.line3}`}>
        <span class="final-h2-line reveal" style="--delay: 60ms">{f.h2.line1}</span>
        <em class="final-h2-em reveal" style="--delay: 150ms">{f.h2.emphasis}</em>
        {
          f.h2.line3 && (
            <span class="final-h2-dim reveal" style="--delay: 240ms">
              {f.h2.line3}
            </span>
          )
        }
      </h2>

      <p class="final-subtitle font-body reveal" style="--delay: 330ms">
        {f.subtitle}
      </p>

    <a  href={WA_HREF}
      target="_blank" rel="noopener noreferrer" class="final-cta font-body reveal" style="--delay: 420ms"
      aria-label="Abrir WhatsApp con IndexArts" >
      <span class="final-cta-text">{f.cta}</span>
      <span class="final-cta-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
          <path
            d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.841.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
          ></path>
        </svg>
      </span>
    </div>

    <ul class="final-trust reveal" style="--delay: 510ms" role="list" aria-label="Garantías">
      {
        f.trust.map((item) => (
          <li class="final-trust-item font-mono">
            <span
              class="final-trust-dot"
              aria-hidden="true"
              style={`background: ${DOT_COLORS[item.dot] ?? DOT_COLORS.neutral}`}
            />
            {item.text}
          </li>
        ))
      }
    </ul>
  </div>

  <aside class="final-aside reveal" style="--delay: 200ms" aria-hidden="true">
    <div class="final-deco-num font-mono" aria-hidden="true">15</div>
    <div class="final-deco-label font-mono">minutos</div>
    <div class="final-deco-sub font-mono">es todo lo que necesitas</div>

    <div class="final-aside-line"></div>

    <address class="final-contact font-mono">
    <a  href={`tel:${copy.nav.phone.replace(/\s/g, '')}`}
      class="final-contact-link" >
      {copy.nav.phone}
    </address>
    <span class="final-contact-sep">·</span>
    <a href="mailto:hola@indexarts.co" class="final-contact-link"> hola@indexarts.co </a>
    <span class="final-contact-sep">·</span>
    <span class="final-contact-place">Barranquilla, Colombia</span>
  </aside>
</section>

<footer class="final-footer">
  <div class="final-footer-inner">
    <span class="final-footer-logo font-head">
      Index<span class="final-logo-accent">Arts</span>
    </span>
    <span class="final-footer-copy font-mono">{footer.copyright}</span>
  </div>
</footer>

<style>
  .final-section {
    position: relative;
    background-color: var(--color-ink-950, #0c0c0c);
    padding: var(--section-py) var(--section-px) 0;
    overflow: hidden;
    isolation: isolate;
    border-top: 1px solid var(--color-border);
  }

  .final-noise {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.022;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
  }

  .final-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      ellipse 60% 55% at 10% 50%,
      rgba(192, 57, 43, 0.07) 0%,
      rgba(192, 57, 43, 0.02) 45%,
      transparent 100%
    );
    pointer-events: none;
  }

  .final-inner {
    position: relative;
    z-index: 1;
    max-width: var(--width-content, 1080px);
    margin: 0 auto;
    padding-bottom: var(--section-py);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(40px, 8vw, 100px);
    align-items: start;
  }

  .final-eyebrow {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.3);
    margin-bottom: clamp(24px, 4vw, 44px);
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-border-2);
  }

  .final-h2 {
    display: flex;
    flex-direction: column;
    gap: 0.04em;
    margin: 0 0 clamp(18px, 3vw, 36px);
    max-width: 580px;
  }

  .final-h2-line {
    display: block;
    font-size: clamp(2.4rem, 6vw, 5.4rem);
    font-weight: 300;
    line-height: 1.02;
    color: var(--color-cream-100, #f2ede6);
    font-style: normal;
  }

  .final-h2-em {
    display: block;
    font-size: clamp(2.4rem, 6vw, 5.4rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.02;
    color: var(--color-brand-red, #c0392b);
    letter-spacing: -0.01em;
  }

  .final-h2-dim {
    display: block;
    font-size: clamp(1.6rem, 4vw, 3.6rem);
    font-weight: 300;
    line-height: 1.08;
    color: rgba(242, 237, 230, 0.32);
    font-style: normal;
  }

  .final-subtitle {
    font-size: clamp(0.85rem, 1.4vw, 1.02rem);
    line-height: 1.78;
    color: rgba(242, 237, 230, 0.55);
    max-width: 500px;
    margin: 0 0 clamp(24px, 4vw, 44px);
  }

  .final-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--color-brand-red, #c0392b);
    color: #fff;
    font-size: clamp(13px, 1.3vw, 15px);
    font-weight: 500;
    padding: clamp(14px, 2vw, 16px) clamp(20px, 3vw, 28px);
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
    transition:
      background 0.22s ease,
      gap 0.22s ease;
    animation: btnAura 3s infinite;
    margin-bottom: clamp(20px, 3.5vw, 36px);
    min-height: 48px; /* touch target */
  }

  .final-cta:hover {
    background: var(--color-brand-red2, #e74c3c);
    gap: 16px;
  }

  .final-cta-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.9;
  }

  .final-trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .final-trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: clamp(9px, 1vw, 10px);
    letter-spacing: 0.06em;
    color: rgba(242, 237, 230, 0.38);
    line-height: 1.4;
  }

  .final-trust-dot {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .final-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    padding-top: clamp(40px, 7vw, 100px);
    gap: 4px;
  }

  .final-deco-num {
    font-size: clamp(60px, 10vw, 130px);
    font-weight: 500;
    color: rgba(242, 237, 230, 0.055);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 4px;
    transition: color 0.4s ease;
  }

  .final-section:hover .final-deco-num {
    color: rgba(192, 57, 43, 0.08);
  }

  .final-deco-label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.2);
    margin-bottom: 2px;
  }

  .final-deco-sub {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.12);
  }

  .final-aside-line {
    width: 40px;
    height: 1px;
    background: var(--color-border-2);
    margin: 20px 0;
    align-self: flex-end;
  }

  .final-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    font-style: normal;
    font-size: 9px;
    letter-spacing: 0.08em;
  }

  .final-contact-link {
    color: rgba(242, 237, 230, 0.3);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .final-contact-link:hover {
    color: rgba(242, 237, 230, 0.7);
  }
  .final-contact-sep {
    color: rgba(242, 237, 230, 0.1);
  }
  .final-contact-place {
    color: rgba(242, 237, 230, 0.18);
  }

  .final-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    padding: 22px 0;
  }

  .final-footer-inner {
    max-width: var(--width-content, 1080px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .final-footer-logo {
    font-size: clamp(15px, 2vw, 20px);
    font-weight: 700;
    color: var(--color-cream-100, #f2ede6);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .final-logo-accent {
    color: var(--color-brand-red, #c0392b);
  }

  .final-footer-copy {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.2);
  }

  @keyframes btnAura {
    0%,
    100% {
      box-shadow: 0 4px 28px rgba(192, 57, 43, 0.28);
    }
    50% {
      box-shadow: 0 4px 44px rgba(192, 57, 43, 0.52);
    }
  }

  .final-section .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity 0.8s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms);
  }

  .final-section .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media (max-width: 780px) {
    .final-inner {
      grid-template-columns: 1fr;
    }

    .final-aside {
      align-items: flex-start;
      text-align: left;
      padding-top: 0;
      padding-bottom: clamp(28px, 5vw, 48px);
      border-top: 1px solid var(--color-border);
      order: -1; /* sube el aside al inicio en mobile como dato de credibilidad */
    }

    .final-aside-line {
      align-self: flex-start;
    }
    .final-contact {
      align-items: flex-start;
    }

    .final-footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }

    .final-cta {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible')
          io.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.1 }
  )

  document.querySelectorAll('#final .reveal').forEach((el) => io.observe(el))
</script>
