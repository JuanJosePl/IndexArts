---
/**
 * src/components/sections/FinalCta.astro
 *
 * Sección CTA final — vuelve al mundo oscuro.
 * H2 por líneas con énfasis tipográfico editorial.
 * Trust items con dot de color semántico.
 * Botón con aura animada (brand-red).
 * Ruido + gradiente radial de profundidad.
 *
 * Datos: solo copy — sin props, sin dataStore.
 * WA: href construido estáticamente (no se necesita hook — es Astro puro).
 */
import { copy } from '@/data/copy'

const { finalCta: f, footer } = copy

const WA_PHONE = import.meta.env.PUBLIC_WA_PHONE ?? '573001234567'
const WA_MSG   = encodeURIComponent('Hola, quiero mi diagnóstico gratuito ahora.')
const WA_HREF  = `https://wa.me/${WA_PHONE}?text=${WA_MSG}`

const DOT_COLORS: Record<string, string> = {
  green:   'var(--color-brand-green, #0B7A45)',
  neutral: 'rgba(242,237,230,0.28)',
  red:     'var(--color-brand-red, #C0392B)',
}
---

<section
  id="final"
  aria-label="Contactar a IndexArts"
  class="final-section"
>

  {/* ── Ruido ── */}
  <div class="final-noise" aria-hidden="true"></div>

  {/* ── Gradiente radial ── */}
  <div class="final-glow" aria-hidden="true"></div>

  <div class="final-inner">

    {/* ── Columna de contenido ── */}
    <div class="final-content">

      {/* Eyebrow */}
      <span class="final-eyebrow font-mono reveal">{f.eyebrow}</span>

      {/* H2 por líneas */}
      <h2 class="final-h2 font-head" aria-label={`${f.h2.line1} ${f.h2.emphasis} ${f.h2.line3}`}>
        <span class="final-h2-line reveal" style="--delay: 60ms">{f.h2.line1}</span>
        <em class="final-h2-em reveal" style="--delay: 150ms">{f.h2.emphasis}</em>
        <span class="final-h2-dim reveal" style="--delay: 240ms">{f.h2.line3}</span>
      </h2>

      {/* Subtítulo */}
      <p class="final-subtitle font-body reveal" style="--delay: 330ms">
        {f.subtitle}
      </p>

      {/* CTA primario */}
      <a
        href={WA_HREF}
        target="_blank"
        rel="noopener noreferrer"
        class="final-cta font-body reveal"
        style="--delay: 420ms"
        aria-label="Abrir WhatsApp con IndexArts"
      >
        <span class="final-cta-text">{f.cta}</span>
        <span class="final-cta-icon" aria-hidden="true">
          {/* WhatsApp icon inline */}
          <svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
            <path d="M12.031 6.172c-3.181 0-5.767 2.586-5.768 5.766-.001 1.298.38 2.27 1.019 3.287l-.582 2.128 2.182-.573c.978.58 1.911.928 3.145.929 3.178 0 5.767-2.587 5.768-5.766.001-3.187-2.575-5.771-5.764-5.771zm3.392 8.244c-.144.405-.837.774-1.17.824-.299.045-.677.063-1.092-.069-.252-.08-.575-.187-.988-.365-1.739-.751-2.874-2.502-2.961-2.617-.087-.116-.708-.94-.708-1.793s.448-1.273.607-1.446c.159-.173.346-.217.462-.217l.332.006c.106.005.249-.04.39.298.144.347.491 1.2.534 1.287.043.087.072.188.014.304-.058.116-.087.188-.173.289l-.26.304c-.087.086-.177.18-.076.354.101.174.449.741.964 1.201.662.591 1.221.774 1.394.86s.274.072.376-.043c.101-.116.433-.506.549-.68.116-.173.231-.145.39-.087s1.011.477 1.184.564c.173.087.289.129.332.202.043.073.043.423-.101.827z"/>
            <path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.126 1.532 5.86L.054 23.454a.75.75 0 0 0 .917.978l5.788-1.515A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.95 9.95 0 0 1-5.187-1.453l-.37-.22-3.84 1.006 1.026-3.745-.241-.386A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
          </svg>
        </span>
      </a>

      {/* Trust items */}
      <ul class="final-trust reveal" style="--delay: 510ms" role="list" aria-label="Garantías">
        {f.trust.map((item) => (
          <li class="final-trust-item font-mono">
            <span
              class="final-trust-dot"
              aria-hidden="true"
              style={`background: ${DOT_COLORS[item.dot] ?? DOT_COLORS.neutral}`}
            ></span>
            {item.text}
          </li>
        ))}
      </ul>

    </div>

    {/* ── Panel derecho — número grande decorativo + info ── */}
    <aside class="final-aside reveal" style="--delay: 200ms" aria-hidden="true">

      {/* Número grande decorativo */}
      <div class="final-deco-num font-mono" aria-hidden="true">15</div>
      <div class="final-deco-label font-mono">minutos</div>
      <div class="final-deco-sub font-mono">es todo lo que necesitas</div>

      {/* Línea separadora */}
      <div class="final-aside-line"></div>

      {/* Info de contacto */}
      <address class="final-contact font-mono">
        <a
          href={`tel:${copy.nav.phone.replace(/\s/g,'')}`}
          class="final-contact-link"
        >
          {copy.nav.phone}
        </a>
        <span class="final-contact-sep">·</span>
        <a href="mailto:hola@indexarts.co" class="final-contact-link">
          hola@indexarts.co
        </a>
        <span class="final-contact-sep">·</span>
        <span class="final-contact-place">Barranquilla, Colombia</span>
      </address>

    </aside>

  </div>

  {/* ── Footer integrado ── */}
  <footer class="final-footer">
    <div class="final-footer-inner">
      <span class="final-footer-logo font-head">
        Index<span class="final-logo-accent">Arts</span>
      </span>
      <span class="final-footer-copy font-mono">{footer.copyright}</span>
    </div>
  </footer>

</section>

<style>
  /* ── Sección ── */
  .final-section {
    position: relative;
    background-color: var(--color-ink-950, #0C0C0C);
    padding: var(--section-py) var(--section-px) 0;
    overflow: hidden;
    isolation: isolate;
    border-top: 1px solid var(--color-border);
  }

  /* ── Noise ── */
  .final-noise {
    position: absolute;
    inset: 0;
    z-index: 0;
    opacity: 0.022;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-size: 200px 200px;
    pointer-events: none;
  }

  /* ── Glow radial — punto de luz rojo/brand en el fondo ── */
  .final-glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: radial-gradient(
      ellipse 60% 55% at 10% 50%,
      rgba(192, 57, 43, 0.07) 0%,
      rgba(192, 57, 43, 0.02) 45%,
      transparent 100%
    );
    pointer-events: none;
  }

  /* ── Inner ── */
  .final-inner {
    position: relative;
    z-index: 1;
    max-width: var(--width-content, 1080px);
    margin: 0 auto;
    padding-bottom: var(--section-py);
    display: grid;
    grid-template-columns: 1fr auto;
    gap: clamp(40px, 8vw, 100px);
    align-items: start;
  }

  /* ── Eyebrow ── */
  .final-eyebrow {
    display: inline-block;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.3);
    margin-bottom: clamp(28px, 5vw, 44px);
    padding-bottom: 6px;
    border-bottom: 1px solid var(--color-border-2);
  }

  /* ── H2 ── */
  .final-h2 {
    display: flex;
    flex-direction: column;
    gap: 0.04em;
    margin: 0 0 clamp(20px, 3.5vw, 36px);
    max-width: 580px;
  }

  .final-h2-line {
    display: block;
    font-size: clamp(2.6rem, 6.5vw, 5.4rem);
    font-weight: 300;
    line-height: 1.02;
    color: var(--color-cream-100, #F2EDE6);
    font-style: normal;
  }

  .final-h2-em {
    display: block;
    font-size: clamp(2.6rem, 6.5vw, 5.4rem);
    font-weight: 700;
    font-style: italic;
    line-height: 1.02;
    color: var(--color-brand-red, #C0392B);
    letter-spacing: -0.01em;
  }

  .final-h2-dim {
    display: block;
    font-size: clamp(1.8rem, 4.5vw, 3.6rem);
    font-weight: 300;
    line-height: 1.08;
    color: rgba(242, 237, 230, 0.32);
    font-style: normal;
  }

  /* ── Subtítulo ── */
  .final-subtitle {
    font-size: clamp(0.88rem, 1.45vw, 1.02rem);
    line-height: 1.78;
    color: rgba(242, 237, 230, 0.55);
    max-width: 500px;
    margin: 0 0 clamp(28px, 4vw, 44px);
  }

  /* ── CTA ── */
  .final-cta {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: var(--color-brand-red, #C0392B);
    color: #fff;
    font-size: clamp(13px, 1.3vw, 15px);
    font-weight: 500;
    padding: 16px 28px;
    text-decoration: none;
    letter-spacing: 0.01em;
    position: relative;
    transition: background 0.22s ease, gap 0.22s ease;
    animation: btnAura 3s infinite;
    margin-bottom: clamp(24px, 4vw, 36px);
  }

  .final-cta:hover {
    background: var(--color-brand-red2, #E74C3C);
    gap: 16px;
  }

  .final-cta-icon {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    opacity: 0.9;
  }

  /* ── Trust items ── */
  .final-trust {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .final-trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(242, 237, 230, 0.38);
    line-height: 1.4;
  }

  .final-trust-dot {
    display: block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* ── Aside decorativo ── */
  .final-aside {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    text-align: right;
    padding-top: clamp(60px, 8vw, 100px);
    gap: 4px;
  }

  .final-deco-num {
    font-size: clamp(72px, 11vw, 130px);
    font-weight: 500;
    color: rgba(242, 237, 230, 0.055);
    line-height: 1;
    letter-spacing: -0.04em;
    margin-bottom: 4px;
    transition: color 0.4s ease;
  }

  .final-section:hover .final-deco-num {
    color: rgba(192, 57, 43, 0.08);
  }

  .final-deco-label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.2);
    margin-bottom: 2px;
  }

  .final-deco-sub {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.12);
  }

  .final-aside-line {
    width: 40px;
    height: 1px;
    background: var(--color-border-2);
    margin: 20px 0;
    align-self: flex-end;
  }

  .final-contact {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 6px;
    font-style: normal;
    font-size: 9px;
    letter-spacing: 0.08em;
  }

  .final-contact-link {
    color: rgba(242, 237, 230, 0.3);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .final-contact-link:hover {
    color: rgba(242, 237, 230, 0.7);
  }

  .final-contact-sep {
    color: rgba(242, 237, 230, 0.1);
  }

  .final-contact-place {
    color: rgba(242, 237, 230, 0.18);
  }

  /* ── Footer ── */
  .final-footer {
    position: relative;
    z-index: 1;
    border-top: 1px solid var(--color-border);
    padding: 22px 0;
  }

  .final-footer-inner {
    max-width: var(--width-content, 1080px);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
  }

  .final-footer-logo {
    font-size: clamp(16px, 2vw, 20px);
    font-weight: 700;
    color: var(--color-cream-100, #F2EDE6);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .final-logo-accent {
    color: var(--color-brand-red, #C0392B);
  }

  .final-footer-copy {
    font-size: 9px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(242, 237, 230, 0.2);
  }

  /* ── Animación aura del botón (definida también en global.css) ── */
  @keyframes btnAura {
    0%,  100% { box-shadow: 0 4px 28px rgba(192, 57, 43, 0.28); }
    50%        { box-shadow: 0 4px 44px rgba(192, 57, 43, 0.52); }
  }

  /* ── Reveal — hereda del global pero especificamos las variables ── */
  .final-section .reveal {
    opacity: 0;
    transform: translateY(20px);
    transition:
      opacity  0.8s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms),
      transform 0.8s cubic-bezier(0.22, 1, 0.36, 1) var(--delay, 0ms);
  }

  .final-section .reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Responsive ── */
  @media (max-width: 780px) {
    .final-inner {
      grid-template-columns: 1fr;
    }

    .final-aside {
      align-items: flex-start;
      text-align: left;
      padding-top: 0;
      padding-bottom: clamp(28px, 5vw, 48px);
      border-top: 1px solid var(--color-border);
    }

    .final-aside-line { align-self: flex-start; }
    .final-contact { align-items: flex-start; }

    .final-footer-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>

<script>
  // IntersectionObserver — activa .is-visible en los .reveal del CTA final
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible')
          io.unobserve(entry.target)
        }
      })
    },
    { threshold: 0.1 }
  )

  document
    .querySelectorAll('#final .reveal')
    .forEach((el) => io.observe(el))
</script>