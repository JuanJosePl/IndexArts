---
/**
 * src/components/sections/Stats.astro
 */
import { dataStore } from '@/data'
import { copy } from '@/data/copy'
import AnimatedStats from '@/components/islands/AnimatedStats'

const stats = await dataStore.metrics.transition()
const { stats: statsCopy } = copy
---

<section
  id="trans"
  style={`
    padding: var(--section-py) var(--section-px);
    background: linear-gradient(
      180deg,
      var(--color-ink-800) 0%,
      var(--color-cream-200) 100%
    );
  `}
>
  <span
    class="reveal mb-11 inline-block pb-1.5 font-mono text-[9px] tracking-[0.18em] uppercase"
    style="
      color: rgba(242,237,230,0.30);
      border-bottom: 1px solid rgba(242,237,230,0.14);
    "
  >
    {statsCopy.eyebrow}
  </span>

  <AnimatedStats stats={stats} client:visible />
</section>

<script>
  const io = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add('is-visible')
          io.unobserve(e.target)
        }
      })
    },
    { threshold: 0.2 }
  )
  document.querySelectorAll('#trans .reveal').forEach((el) => io.observe(el))
</script>
