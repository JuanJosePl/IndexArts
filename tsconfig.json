{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*":          ["./src/*"],
      "@domain/*":    ["./src/domain/*"],
      "@data/*":      ["./src/data/*"],
      "@ui/*":        ["./src/components/ui/*"],
      "@islands/*":   ["./src/components/islands/*"],
      "@sections/*":  ["./src/components/sections/*"],
      "@layout/*":    ["./src/components/layout/*"],
      "@utils/*":     ["./src/utils/*"],
      "@hooks/*":     ["./src/hooks/*"],
      "@types/*":     ["./src/types/*"]
    }
  },
  "include": ["src", "*.config.*"]
}
